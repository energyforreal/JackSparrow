# Agent service environment template
DATABASE_URL=postgresql://user:password@localhost:5432/trading_agent
REDIS_URL=redis://localhost:6379

# Delta Exchange
DELTA_EXCHANGE_API_KEY=your_api_key
DELTA_EXCHANGE_API_SECRET=your_api_secret
DELTA_EXCHANGE_BASE_URL=https://api.delta.exchange

# Model configuration
MODEL_PATH=
# v4 (50 features) or v5 (expanded ~122 features)
# MODEL_DIR=./agent/model_storage/jacksparrow_v4_BTCUSD
MODEL_DIR=./agent/model_storage/jacksparrow_v5_BTCUSD_2026-03-19
MODEL_DISCOVERY_ENABLED=true
MODEL_AUTO_REGISTER=true

# Agent configuration
AGENT_START_MODE=MONITORING
AGENT_SYMBOL=BTCUSD
AGENT_INTERVAL=15m

# Risk management
MAX_POSITION_SIZE=0.1
MAX_PORTFOLIO_HEAT=0.3
STOP_LOSS_PERCENTAGE=0.004
TAKE_PROFIT_PERCENTAGE=0.006
# Trading Agent Improvements (optional)
# MAX_SIGNAL_AGE_SECONDS=10
# TRAILING_STOP_PERCENTAGE=0.015
# MAX_POSITION_HOLD_HOURS=24
# WEBSOCKET_SL_TP_ENABLED=true
# MTF_CONFIRMATION_ENABLED=false
# MTF_DECISION_ENGINE_ENABLED=true
# MTF_TREND_TIMEFRAME=15m
# MTF_ENTRY_TIMEFRAME=5m
# MTF_FILTER_TIMEFRAME=none
# MTF_TREND_FALLBACK_TIMEFRAMES=30m,1h,2h,4h
# MTF_ENTRY_FALLBACK_TIMEFRAMES=15m,30m,1h
# MTF_ENTRY_MIN_CONFIDENCE=0.6
# MTF_TREND_SIGNAL_THRESHOLD=0.1
# MTF_ENTRY_SIGNAL_THRESHOLD=0.15
# MTF_USE_ENTRY_PROBA_GATING=true
# MTF_TREND_MIN_BUY_PROB=0.6
# MTF_TREND_MIN_SELL_PROB=0.6
# MTF_ENTRY_MIN_BUY_PROB=0.6
# MTF_ENTRY_MIN_SELL_PROB=0.6
# MTF_STRONG_MIN_BUY_PROB=0.72
# MTF_STRONG_MIN_SELL_PROB=0.72
# USE_ML_EXIT_MODEL=false
# SR_STRENGTH_FILTER_ENABLED=true
# BLOCK_BUY_MIN_SR_RESISTANCE_STRENGTH=0.7
# BLOCK_SELL_MIN_SR_SUPPORT_STRENGTH=0.7
# TIMEFRAMES=3m,5m,15m
# MODEL_DISAGREEMENT_THRESHOLD=0.4
# HALF_SPREAD_PCT=0.0002
# PAPER_TICKER_MAX_AGE_SECONDS=10.0
# PAPER_FILL_PRICE_FALLBACK_ENABLED=true
# MIN_MONITOR_INTERVAL_SECONDS=2.0
# POSITION_MONITOR_INTERVAL_SECONDS=15.0

# Logging
LOG_LEVEL=INFO
LOG_FORWARDING_ENABLED=false
LOG_FORWARDING_ENDPOINT=


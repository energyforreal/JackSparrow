# Agent service environment template (local `python -m agent...` only).
# Docker Compose uses the repository root .env — see ../.env.example.
DATABASE_URL=postgresql://user:password@localhost:5432/trading_agent
REDIS_URL=redis://localhost:6379

# Delta Exchange
DELTA_EXCHANGE_API_KEY=your_api_key
DELTA_EXCHANGE_API_SECRET=your_api_secret
DELTA_EXCHANGE_BASE_URL=https://api.delta.exchange

# Model configuration
MODEL_PATH=
# v15 pipeline bundle (5m/15m) or legacy v5 v4_ensemble path
MODEL_DIR=./agent/model_storage/jacksparrow_v15_BTCUSD_2026-04-05
MODEL_FORMAT=auto
MODEL_DISCOVERY_ENABLED=true
MODEL_AUTO_REGISTER=true
# V15_SIGNAL_LOGIC_ENABLED=true
# V15_DISABLE_MTF_SYNTHESIS=true
# ATR_TRAILING_MULT=2.0
# MIN_HOLD_BARS=3
# HTF_CACHE_TTL_SECONDS=840

# Agent configuration
AGENT_START_MODE=MONITORING
AGENT_SYMBOL=BTCUSD
AGENT_INTERVAL=15m
# Optional: neutral midpoint for binary XGBoost probability normalization in xgboost_node.
# Keep 0.5 for standard probability outputs; tune only if your calibrated distribution is shifted.
# XGB_BINARY_DECISION_MIDPOINT=0.5
# Optional: label threshold for "strong bullish/bearish consensus" wording in reasoning step 3.
# REASONING_CONSENSUS_LABEL_THRESHOLD=0.5

# Risk management
MAX_POSITION_SIZE=0.1
MAX_PORTFOLIO_HEAT=0.3
STOP_LOSS_PERCENTAGE=0.0025
TAKE_PROFIT_PERCENTAGE=0.003
# Trading Agent Improvements (optional)
# MAX_SIGNAL_AGE_SECONDS=10
# TRAILING_STOP_PERCENTAGE=0.015
# MAX_POSITION_HOLD_HOURS=24
# WEBSOCKET_SL_TP_ENABLED=true
# MTF_CONFIRMATION_ENABLED=false
# MTF_DECISION_ENGINE_ENABLED=true
# MTF_TREND_TIMEFRAME=15m
# MTF_ENTRY_TIMEFRAME=5m
# MTF_FILTER_TIMEFRAME=none
# MTF_TREND_FALLBACK_TIMEFRAMES=30m,1h,2h,4h
# MTF_ENTRY_FALLBACK_TIMEFRAMES=15m,30m,1h
# MTF_ENTRY_MIN_CONFIDENCE=0.52
# MTF_TREND_SIGNAL_THRESHOLD=0.1
# MTF_ENTRY_SIGNAL_THRESHOLD=0.15
# MTF_USE_ENTRY_PROBA_GATING=true
# --- MTF probability gates (see agent/core/mtf_decision_engine.py) ---
# After retraining, align these with validation diagnostics from notebooks/JackSparrow_Trading_Colab_v5.ipynb
# (cell "5.2b Validation probability diagnostics"): use P50/P80/P95 of class-1 proba on the validation split
# so entry gates sit above noise (e.g. if P95 long ~0.42, try MTF_ENTRY_MIN_BUY_PROB=0.43–0.48 instead of 0.6).
# For 1h trend + 15m entry: MTF_TREND_TIMEFRAME=1h and MTF_ENTRY_TIMEFRAME=15m (requires models for those TFs).
# MTF_MIN_CONFIDENCE_GAP=0.05
# MTF_TREND_MIN_BUY_PROB=0.50
# MTF_TREND_MIN_SELL_PROB=0.50
# MTF_ENTRY_MIN_BUY_PROB=0.50
# MTF_ENTRY_MIN_SELL_PROB=0.50
# MTF_STRONG_MIN_BUY_PROB=0.60
# MTF_STRONG_MIN_SELL_PROB=0.60
# ENTRY_LONG_SHORT_MIN_GAP=0.0
# USE_ML_EXIT_MODEL=false
# SR_STRENGTH_FILTER_ENABLED=true
# BLOCK_BUY_MIN_SR_RESISTANCE_STRENGTH=0.7
# BLOCK_SELL_MIN_SR_SUPPORT_STRENGTH=0.7
# TIMEFRAMES=3m,5m,15m
# MODEL_DISAGREEMENT_THRESHOLD=0.4
# HALF_SPREAD_PCT=0.0002
# PAPER_TICKER_MAX_AGE_SECONDS=10.0
# PAPER_FILL_PRICE_FALLBACK_ENABLED=true
# MIN_MONITOR_INTERVAL_SECONDS=2.0
# POSITION_MONITOR_INTERVAL_SECONDS=15.0

# Logging
LOG_LEVEL=INFO
LOG_FORWARDING_ENABLED=false
LOG_FORWARDING_ENDPOINT=


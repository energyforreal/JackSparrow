# syntax=docker/dockerfile:1.7
# Development Dockerfile for Frontend
# Source code is mounted as volume, dependencies are installed

FROM node:20-bullseye-slim

WORKDIR /app

ENV NODE_ENV=development \
    NEXT_TELEMETRY_DISABLED=1 \
    PORT=3000 \
    HOSTNAME="0.0.0.0"

# Create non-root user
RUN groupadd -r frontend && useradd -r -g frontend frontend && \
    mkdir -p /app /logs /app/.next && \
    chown -R frontend:frontend /app /logs

# Copy package files for dependency installation
COPY --chown=frontend:frontend package*.json ./

# Install all dependencies (including devDependencies for development)
RUN npm ci && npm cache clean --force

# Note: Source code will be mounted as volume in docker-compose.dev.yml
# No COPY of source code here - this enables hot-reload
# node_modules and .next directories will be excluded via volumes

# Switch to non-root user
USER frontend

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=5s --start-period=30s --retries=3 \
    CMD node -e "require('http').get('http://localhost:3000', (r) => {process.exit(r.statusCode < 500 ? 0 : 1)})" || exit 1

# Development command with hot-reload
CMD ["npm", "run", "dev"]


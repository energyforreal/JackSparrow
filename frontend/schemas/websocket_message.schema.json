{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jacksparrow.local/schemas/websocket_message.schema.json",
  "title": "JackSparrowDashboardWebSocketInbound",
  "oneOf": [
    {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "enum": ["data_update", "agent_update", "system_update"] },
        "resource": { "type": "string" },
        "data": {},
        "payload": {},
        "schema_version": { "type": "integer", "minimum": 1 },
        "server_timestamp": { "type": ["string", "number"] },
        "server_timestamp_ms": { "type": "number" }
      },
      "additionalProperties": true
    },
    {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "const": "response" },
        "success": { "type": "boolean" },
        "request_id": { "type": "string" },
        "correlation_id": { "type": "string" },
        "command": { "type": "string" },
        "schema_version": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": true
    },
    {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "const": "subscribed" },
        "channels": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    {
      "type": "object",
      "required": ["type"],
      "properties": { "type": { "type": "string", "minLength": 1 } },
      "additionalProperties": true
    }
  ]
}

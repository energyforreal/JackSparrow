# Backend service environment template
DATABASE_URL=postgresql://user:password@localhost:5432/trading_agent
# Default true: create tables/enums on startup. false = external DDL only (backend will fail fast if init enabled and DB errors).
# AUTO_CREATE_DB_SCHEMA=true
REDIS_URL=redis://localhost:6379

# Delta Exchange
DELTA_EXCHANGE_API_KEY=your_api_key
DELTA_EXCHANGE_API_SECRET=your_api_secret
DELTA_EXCHANGE_BASE_URL=https://api.delta.exchange

# Agent communication
AGENT_COMMAND_QUEUE=agent_commands
AGENT_RESPONSE_QUEUE=agent_responses
# Feature server (align with root/docker: 8002; agent exposes features on 8002)
FEATURE_SERVER_URL=http://localhost:8002
# Agent WebSocket (Docker: ws://agent:8003; local: ws://localhost:8003)
AGENT_WS_URL=ws://localhost:8003

# Security
JWT_SECRET_KEY=dev-jwt-secret
API_KEY=dev-api-key

# Logging
LOG_LEVEL=INFO
LOG_FORWARDING_ENABLED=false
LOG_FORWARDING_ENDPOINT=

# Optional services
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=


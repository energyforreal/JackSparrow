# JackSparrow root environment template (copy to .env and customize)
# Required variables have no safe defaults in docker-compose.yml — fill all secrets before `docker compose up`.
# Full-stack Docker uses THIS file (root .env) via env_file — not agent/.env.

# -------------------------------------------------------------------
# Infrastructure & Shared Services
# -------------------------------------------------------------------
POSTGRES_USER=jacksparrow
POSTGRES_PASSWORD=change-me-use-strong-password
POSTGRES_DB=trading_agent
POSTGRES_PORT=5432
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis-password
# URL-encode special characters in passwords for Redis URLs (e.g. @ -> %40)
DATABASE_URL=postgresql://jacksparrow:change-me-use-strong-password@localhost:5432/trading_agent
# When true (default), backend runs SQLAlchemy create_all on startup so tables/enums exist (no Alembic in this repo).
# Set to false only if you apply DDL yourself. If Postgres was left half-initialized, remove the compose volume
# postgres-data (or drop/recreate the DB) and restart so schema init can succeed.
# AUTO_CREATE_DB_SCHEMA=true
REDIS_URL=redis://:change-me-redis-password@localhost:6379/0
# Local (non-Docker): feature server reachable on localhost.
# Docker Compose overrides this to http://agent:8002 for backend container traffic.
FEATURE_SERVER_URL=http://localhost:8002
BACKEND_PORT=8000
FRONTEND_PORT=3000
# Feature HTTP API (host port when using compose). AGENT_WS_PORT is the *host* publish port for the
# agent command WebSocket; the container always listens on 8003. docker-compose.yml sets
# backend AGENT_WS_URL to ws://agent:8003 (Docker network), independent of this value.
FEATURE_SERVER_PORT=8002
AGENT_WS_PORT=8003
# Docker Compose: optional override for in-container model bundle path (see docker-compose agent MODEL_DIR).
# Default in compose: /app/agent/model_storage/jacksparrow_v15_BTCUSD_2026-04-05 (v15 5m/15m pipeline bundle)
# AGENT_MODEL_DIR=/app/agent/model_storage/jacksparrow_v5_BTCUSD_2026-03-21

# -------------------------------------------------------------------
# Delta Exchange Credentials (required)
# -------------------------------------------------------------------
DELTA_EXCHANGE_API_KEY=your-delta-api-key
DELTA_EXCHANGE_API_SECRET=your-delta-api-secret
DELTA_EXCHANGE_BASE_URL=https://api.india.delta.exchange

DELTA_API_KEY=your-delta-api-key
DELTA_API_SECRET=your-delta-api-secret
DELTA_API_URL=https://api.india.delta.exchange

# -------------------------------------------------------------------
# Backend Security & API Settings
# -------------------------------------------------------------------
JWT_SECRET_KEY=use-a-long-random-secret-min-32-chars
API_KEY=use-a-long-random-api-key-min-32-chars
# Browser-visible origins only (no Docker-internal hosts here)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000
# Optional: merged in backend for Docker/internal (default in compose: http://frontend:3000)
CORS_INTERNAL_ORIGINS=http://frontend:3000
# ENVIRONMENT=production with real secrets, or leave development and set STRICT_SECRETS=true to reject placeholders
# ENVIRONMENT=development
# STRICT_SECRETS=false
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
REDIS_MAX_CONNECTIONS=12
# Backend status command timeout (seconds) for get_status.
# Increase in CPU-heavy environments to reduce false websocket timeouts.
# AGENT_STATUS_COMMAND_TIMEOUT_SECONDS=15
# Backend status UX smoothing for transient agent command timeouts.
# During this grace window, backend reuses last-known-good agent status.
# AGENT_STATUS_TIMEOUT_GRACE_SECONDS=30

# Logging
LOG_LEVEL=INFO
BACKEND_LOG_LEVEL=INFO
AGENT_LOG_LEVEL=INFO
LOG_FORWARDING_ENABLED=false
LOG_FORWARDING_ENDPOINT=
LOG_INCLUDE_STACKTRACE=false

# -------------------------------------------------------------------
# Agent Configuration
# -------------------------------------------------------------------
AGENT_START_MODE=MONITORING
AGENT_SYMBOL=BTCUSD
AGENT_INTERVAL=15m
FEATURE_SERVER_HOST=0.0.0.0
PAPER_TRADING_MODE=true
# Backend startup behavior in paper mode:
# true  = clear positions/trades on each backend startup (fresh session)
# false = preserve paper portfolio/history across restarts
# RESET_PAPER_STATE_ON_STARTUP=true

# Risk Management
MAX_POSITION_SIZE=0.10
MAX_PORTFOLIO_HEAT=0.30
# Scalping defaults (0.25% / 0.3%); match Colab TP_PCT/SL_PCT after retrain.
STOP_LOSS_PERCENTAGE=0.0025
TAKE_PROFIT_PERCENTAGE=0.003
MAX_DAILY_LOSS=0.05
MAX_DRAWDOWN=0.15
MAX_CONSECUTIVE_LOSSES=5
MIN_TIME_BETWEEN_TRADES=300

# Perpetual Futures Contract (Delta BTCUSD Perpetual)
CONTRACT_TYPE=perpetual_futures
PRODUCT_ID=27
SYMBOL=BTCUSD
CONTRACT_VALUE_BTC=0.001
TICK_SIZE=0.50
TAKER_FEE_RATE=0.0005
MAKER_FEE_RATE=0.0002
FUNDING_INTERVAL_HOURS=8
FUNDING_INTEREST_RATE=0.0001
DEFAULT_LEVERAGE=5
MAX_LEVERAGE=20
MIN_LEVERAGE=1
ISOLATED_MARGIN=true
FUNDING_STOP_ENABLED=true
FUNDING_STOP_THRESHOLD=0.0005
ORDER_TYPE=market
SLIPPAGE_BPS=5
MIN_LOT_SIZE=1
MAX_LOTS_PER_ORDER=100
ENABLE_FUNDING_FEATURES=true
ENABLE_OI_FEATURES=true
ENABLE_MARK_PRICE_FEATURES=true
ENABLE_ORDERBOOK_FEATURES=true
ACTIVE_TIMEFRAMES=5m,15m,30m,1h,2h

# Trading Session Defaults
INITIAL_BALANCE=20000.0
TRADING_MODE=paper
TRADING_SYMBOL=BTCUSD
# Entry gate: trades are allowed only when confidence is >= 70%.
MIN_CONFIDENCE_THRESHOLD=0.70
# Optional: neutral midpoint used by binary xgboost_node probability-to-signal mapping.
# XGB_BINARY_DECISION_MIDPOINT=0.5
# Optional: threshold for "strong consensus" labeling in reasoning diagnostics.
# REASONING_CONSENSUS_LABEL_THRESHOLD=0.5
UPDATE_INTERVAL=900
TIMEFRAMES=3m,5m,15m

# Model Configuration — local agent: relative path OK. Docker: compose sets MODEL_DIR from AGENT_MODEL_DIR
# (default v15 pipeline bundle); override AGENT_MODEL_DIR when you add a new dated folder.
# Rollback to v4/v5: set MODEL_FORMAT=v4_ensemble and MODEL_DIR to the v5 folder (see docs/03-ml-models.md).
# Symlink option: python scripts/link_model_storage_latest.py agent/model_storage/jacksparrow_v5_BTCUSD_2026-03-21
MODEL_DIR=./agent/model_storage/jacksparrow_v15_BTCUSD_2026-04-05
# v4_ensemble | v15_pipeline | auto (detect from metadata + sibling pipeline pickle)
MODEL_FORMAT=auto
MODEL_DISCOVERY_ENABLED=true
MODEL_AUTO_REGISTER=true

# --- JackSparrow v15 pipeline (5m/15m XGB joblib) ---
# V15_SIGNAL_LOGIC_ENABLED=true
# V15_DISABLE_MTF_SYNTHESIS=true
# V15_FILTER_FEATURE_SOURCE_TF=5m
# CONFIDENCE_PERCENTILE=90
# EDGE_FLOOR=0.15
# ATR_TRAILING_MULT=2.0
# MIN_HOLD_BARS=3
# EDGE_DECAY_THRESHOLD=0.05
# VOLATILITY_FILTER_ENABLED=true
# V15_ATR_PCT_FLOOR=0.0005
# V15_ADX_RANGING_MAX=25
# HTF_CACHE_TTL_SECONDS=840
# Docker Compose sets REQUIRE_MODELS_ON_STARTUP=true by default; use false locally if you have no model artefacts.
# REQUIRE_MODELS_ON_STARTUP=false
# Persist decisions / closes to Postgres (requires DATABASE_URL + migrate_model_governance.py).
# PREDICTION_AUDIT_WRITES_ENABLED=true
# TRADE_OUTCOMES_WRITES_ENABLED=true
# Bounded Redis threshold learning (reads trade_outcomes).
# THRESHOLD_ADAPTER_ENABLED=true
# THRESHOLD_ADAPTER_INTERVAL_SECONDS=3600

# --- Multi-timeframe (MTF) gates (see agent/core/mtf_decision_engine.py) ---
# Defaults in config.py match raw XGB probabilities; tune using validation percentiles in
# notebooks/JackSparrow_Trading_Colab_v5.ipynb (section 5.2b) after each retrain.
# MTF_DECISION_ENGINE_ENABLED=true
# 5m-primary scalping: primary TF drives BUY/SELL; 15m only adjusts position size (never blocks).
# MTF_SIGNAL_ARCHITECTURE=short_tf_primary
# MTF_PRIMARY_SIGNAL_TIMEFRAME=5m
# MTF_CONTEXT_TIMEFRAME=15m
# MTF_PRIMARY_DEAD_ZONE=0.05
# MTF_PRIMARY_EDGE_LONG=0.08
# MTF_PRIMARY_EDGE_SHORT=0.08
# MTF_PRIMARY_STRONG_LONG_MIN_PROB=0.55
# MTF_PRIMARY_STRONG_SHORT_MIN_PROB=0.58
# MTF_CONTEXT_AGREE_EDGE=0.02
# MTF_CONTEXT_ALIGNED_SIZE_MULTIPLIER=1.15
# MTF_CONTEXT_MISALIGNED_SIZE_MULTIPLIER=0.75
# Default stack: 15m trend + 5m entry (matches notebook intro). For higher-TF trend + 15m entry
# (e.g. 1h trend confirms 15m entry), set:
#   MTF_TREND_TIMEFRAME=1h
#   MTF_ENTRY_TIMEFRAME=15m
# (Requires exported models for those timeframes under MODEL_DIR.)
# MTF_TREND_FALLBACK_TIMEFRAMES=30m,1h,2h,4h
# MTF_ENTRY_FALLBACK_TIMEFRAMES=15m,30m,1h
# MTF_ENTRY_MIN_CONFIDENCE=0.52
# MTF_TREND_MIN_BUY_PROB=0.50
# MTF_TREND_MIN_SELL_PROB=0.50
# MTF_ENTRY_MIN_BUY_PROB=0.50
# MTF_ENTRY_MIN_SELL_PROB=0.50
# MTF_STRONG_MIN_BUY_PROB=0.60
# MTF_STRONG_MIN_SELL_PROB=0.60
# MTF_MIN_CONFIDENCE_GAP=0.05
# MTF_TREND_SIGNAL_THRESHOLD=0.1
# MTF_ENTRY_SIGNAL_THRESHOLD=0.15
# Optional: v4 binary long/short only — force neutral when |buy_prob-sell_prob| is tiny (0 = off).
# ENTRY_LONG_SHORT_MIN_GAP=0.05
# Prob-diff MTF (defaults on in config): trend/entry use signed (buy-sell) edges vs absolute floors.
# MTF_TREND_USE_PROB_DIFF=true
# MTF_TREND_PROB_DIFF_EDGE=0.05
# MTF_ENTRY_USE_PROB_DIFF=true
# MTF_ENTRY_PROB_DIFF_EDGE=0.08
# MTF_STRONG_ENTRY_PROB_DIFF=0.15
# MTF_ENTRY_MIN_MAX_PROB_FLOOR=0.0
# Selective scalping: require |buy-sell| in top (100-P)% of recent bars (needs symbol in reasoning).
# MTF_ENTRY_STRENGTH_PERCENTILE_ENABLED=false
# MTF_ENTRY_STRENGTH_PERCENTILE=80
# MTF_ENTRY_STRENGTH_PERCENTILE_MIN_SAMPLES=30
# ENTRY_MIN_VOLATILITY_FOR_TRADE=0.0
# ENTRY_MIN_ATR_PCT_OF_PRICE=0.0

# Agent Communication
AGENT_COMMAND_QUEUE=agent_commands
AGENT_RESPONSE_QUEUE=agent_responses
# Local backend: agent WS on localhost. Full Docker stack: compose overrides to ws://agent:8003.
AGENT_WS_URL=ws://localhost:8003
USE_AGENT_WEBSOCKET=true

# -------------------------------------------------------------------
# Frontend (public URLs; API key is server-only via Next.js /api/backend proxy)
# -------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_BACKEND_PROXY_BASE=/api/backend

# -------------------------------------------------------------------
# Optional: GHCR image names for production deploy (docker compose pull + up --no-build)
# -------------------------------------------------------------------
# BACKEND_IMAGE=ghcr.io/<org>/jacksparrow-backend:latest
# AGENT_IMAGE=ghcr.io/<org>/jacksparrow-agent:latest
# FRONTEND_IMAGE=ghcr.io/<org>/jacksparrow-frontend:latest

# -------------------------------------------------------------------
# Optional Services
# -------------------------------------------------------------------
# Local default (non-Docker). Docker Compose overrides to http://qdrant:6333.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

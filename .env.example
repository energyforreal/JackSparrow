# JackSparrow root environment template (copy to .env and customize)

# -------------------------------------------------------------------
# Infrastructure & Shared Services
# -------------------------------------------------------------------
POSTGRES_USER=jacksparrow
POSTGRES_PASSWORD=jacksparrow
POSTGRES_DB=trading_agent
POSTGRES_PORT=5432
REDIS_PORT=6379
DATABASE_URL=postgresql://jacksparrow:jacksparrow@localhost:5432/trading_agent
REDIS_URL=redis://localhost:6379/0
FEATURE_SERVER_URL=http://localhost:8002
BACKEND_PORT=8000
FRONTEND_PORT=3000
FEATURE_SERVER_PORT=8002
# Agent WebSocket (HTTP remains on 8002; WS moves to 8003 for Docker)
AGENT_WS_PORT=8003

# -------------------------------------------------------------------
# Delta Exchange Credentials (required)
# -------------------------------------------------------------------
DELTA_EXCHANGE_API_KEY=xxx
DELTA_EXCHANGE_API_SECRET=xxx
DELTA_EXCHANGE_BASE_URL=https://api.india.delta.exchange

# Backward compatible aliases
DELTA_API_KEY=xxx
DELTA_API_SECRET=xxx
DELTA_API_URL=https://api.india.delta.exchange

# -------------------------------------------------------------------
# Backend Security & API Settings
# -------------------------------------------------------------------
JWT_SECRET_KEY=xx
API_KEY=xxx
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Logging
LOG_LEVEL=INFO
BACKEND_LOG_LEVEL=INFO
AGENT_LOG_LEVEL=INFO
LOG_FORWARDING_ENABLED=false
LOG_FORWARDING_ENDPOINT=
LOG_INCLUDE_STACKTRACE=false

# -------------------------------------------------------------------
# Agent Configuration
# -------------------------------------------------------------------
AGENT_START_MODE=MONITORING
AGENT_SYMBOL=BTCUSD
AGENT_INTERVAL=15m
FEATURE_SERVER_HOST=0.0.0.0
PAPER_TRADING_MODE=true

# Risk Management
MAX_POSITION_SIZE=0.10
MAX_PORTFOLIO_HEAT=0.30
# Scalping-style defaults (fraction of price): 0.002 = 0.2% SL, 0.003 = 0.3% TP
STOP_LOSS_PERCENTAGE=0.002
TAKE_PROFIT_PERCENTAGE=0.003
MAX_DAILY_LOSS=0.05
MAX_DRAWDOWN=0.15
MAX_CONSECUTIVE_LOSSES=5
MIN_TIME_BETWEEN_TRADES=300
# Trading Agent Improvements (optional)
# MAX_SIGNAL_AGE_SECONDS=10
# TRAILING_STOP_PERCENTAGE=0.015
# MAX_POSITION_HOLD_HOURS=24
# WEBSOCKET_SL_TP_ENABLED=true
# MTF_CONFIRMATION_ENABLED=false
# Multi-timeframe model decision layer (trend + entry; optional 3m filter)
# MTF_DECISION_ENGINE_ENABLED=true
# MTF_TREND_TIMEFRAME=15m
# MTF_ENTRY_TIMEFRAME=5m
# MTF_FILTER_TIMEFRAME=3m
# MTF_TREND_FALLBACK_TIMEFRAMES=30m,1h,2h,4h
# MTF_ENTRY_FALLBACK_TIMEFRAMES=15m,3m,30m,1h
# MTF_ENTRY_MIN_CONFIDENCE=0.6
# MTF_TREND_SIGNAL_THRESHOLD=0.1
# MTF_ENTRY_SIGNAL_THRESHOLD=0.15
# Disable imbalanced exit classifier; exits = TP/SL + trailing + max hold (execution)
# USE_ML_EXIT_MODEL=false
# FEATURE_FILTER_ENABLED=true
# BLOCK_BUY_NEAR_BB_UPPER_PCT=0.92
# MODEL_DISAGREEMENT_THRESHOLD=0.4
# HALF_SPREAD_PCT=0.0002
# PAPER_TICKER_MAX_AGE_SECONDS=10.0
# PAPER_FILL_PRICE_FALLBACK_ENABLED=true
# MIN_MONITOR_INTERVAL_SECONDS=2.0
# POSITION_MONITOR_INTERVAL_SECONDS=15.0

# Trading Session Defaults
INITIAL_BALANCE=10000.0
TRADING_MODE=paper
TRADING_SYMBOL=BTCUSD
MIN_CONFIDENCE_THRESHOLD=0.65
UPDATE_INTERVAL=900
# No 1m — roles: 15m trend, 5m entry, 3m optional filter (align models in MODEL_DIR)
TIMEFRAMES=3m,5m,15m

# Model Configuration
# MODEL_PATH is optional when MODEL_DISCOVERY_ENABLED=true
# If specified, loads a specific model file. Otherwise, models are discovered from MODEL_DIR
# Example: point to a single production model file (optional)
# MODEL_PATH=agent/model_storage/jacksparrow_v4_BTCUSD/entry_model.pkl

# v4 (50 features) or v5 (expanded ~122 features). Extract Colab ZIP into the chosen folder.
# MODEL_DIR=./agent/model_storage/jacksparrow_v4_BTCUSD
MODEL_DIR=./agent/model_storage/jacksparrow_v5_BTCUSD_2026-03-19
MODEL_DISCOVERY_ENABLED=true
MODEL_AUTO_REGISTER=true

# Agent Communication
AGENT_COMMAND_QUEUE=agent_commands
AGENT_RESPONSE_QUEUE=agent_responses
# Local default WebSocket URL for the agent (Docker backend overrides to ws://agent:${AGENT_WS_PORT:-8003})
AGENT_WS_URL=ws://localhost:8003
USE_AGENT_WEBSOCKET=true

# -------------------------------------------------------------------
# Frontend (public) environment variables
# -------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
API_KEY=xxx

# -------------------------------------------------------------------
# Optional Services
# -------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
TELEGRAM_BOT_TOKEN=xxx
TELEGRAM_CHAT_ID=xxx

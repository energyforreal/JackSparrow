CORS_ORIGINS=http://localhost:3000,http://localhost:3001
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Logging
LOG_LEVEL=INFO
BACKEND_LOG_LEVEL=INFO
AGENT_LOG_LEVEL=INFO
LOG_FORWARDING_ENABLED=false
LOG_FORWARDING_ENDPOINT=
LOG_INCLUDE_STACKTRACE=false

# -------------------------------------------------------------------
# Agent Configuration
# -------------------------------------------------------------------
AGENT_START_MODE=MONITORING
AGENT_SYMBOL=BTCUSD
AGENT_INTERVAL=15m
FEATURE_SERVER_HOST=0.0.0.0
PAPER_TRADING_MODE=true

# Risk Management
MAX_POSITION_SIZE=0.10
MAX_PORTFOLIO_HEAT=0.30
STOP_LOSS_PERCENTAGE=0.02
TAKE_PROFIT_PERCENTAGE=0.05
MAX_DAILY_LOSS=0.05
MAX_DRAWDOWN=0.15
MAX_CONSECUTIVE_LOSSES=5
MIN_TIME_BETWEEN_TRADES=300

# Trading Session Defaults
INITIAL_BALANCE=10000.0
TRADING_MODE=paper
TRADING_SYMBOL=BTCUSD
MIN_CONFIDENCE_THRESHOLD=0.65
UPDATE_INTERVAL=900
TIMEFRAMES=15m,1h,4h

# Model Configuration
MODEL_PATH=models/xgboost_BTCUSD_15m.pkl
MODEL_DIR=./agent/model_storage
MODEL_DISCOVERY_ENABLED=true
MODEL_AUTO_REGISTER=true

# Agent Communication
AGENT_COMMAND_QUEUE=agent_commands
AGENT_RESPONSE_QUEUE=agent_responses

# -------------------------------------------------------------------
# Frontend (public) environment variables
# -------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_BACKEND_API_KEY=dev-api-key


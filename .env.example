# -------------------------------------------------------------------
# Backend Security & API Settings
# -------------------------------------------------------------------
JWT_SECRET_KEY=b4838b1edae862a2be581d1b9fbd7dd4af2fa3aeafcddc3aacb70cabaadc7a1c

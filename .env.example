# JackSparrow environment defaults — committed, non-secret values only.
#
# Layered loading (all services share the same model):
#   1. .env.example  (this file, committed) -> non-secret defaults: ports, thresholds,
#                                               feature flags, URLs, model paths.
#   2. .env          (gitignored, root only) -> SECRETS ONLY: DB password, Delta API
#                                               key/secret, JWT_SECRET_KEY, API_KEY,
#                                               REDIS_PASSWORD, optional Qdrant/Telegram
#                                               tokens, and overrides for personal use.
#
# Files are merged in that order, so values in .env override placeholders here for the
# same keys. Real OS environment variables (shell / CI / Docker) override both files.
#
# Backend, agent, frontend (Next.js loadRootEnv), and Docker Compose all read these
# two files. There is no per-service env file — do NOT create agent/.env,
# backend/.env, or frontend/.env(.local). Use only the project root.
#
# Placeholder secret values below (change-me-*, your-delta-api-*, etc.) exist so this
# file is self-documenting and so pydantic-settings can boot in development without a
# .env. In any real (paper or live) deployment, override every secret in .env.

# -------------------------------------------------------------------
# Infrastructure & Shared Services
# -------------------------------------------------------------------
POSTGRES_USER=jacksparrow
POSTGRES_PASSWORD=change-me-use-strong-password
POSTGRES_DB=trading_agent
POSTGRES_PORT=5432
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis-password
# URL-encode special characters in passwords for Redis URLs (e.g. @ -> %40)
DATABASE_URL=postgresql://jacksparrow:change-me-use-strong-password@localhost:5432/trading_agent
# When true (default), backend runs SQLAlchemy create_all on startup so tables/enums exist (no Alembic in this repo).
# Set to false only if you apply DDL yourself. If Postgres was left half-initialized, remove the compose volume
# postgres-data (or drop/recreate the DB) and restart so schema init can succeed.
# AUTO_CREATE_DB_SCHEMA=true
REDIS_URL=redis://:change-me-redis-password@localhost:6379/0
# Local (non-Docker): feature server reachable on localhost.
# Docker Compose overrides this to http://agent:8002 for backend container traffic.
FEATURE_SERVER_URL=http://localhost:8002
BACKEND_PORT=8000
FRONTEND_PORT=3000
# Feature HTTP API (host port when using compose). AGENT_WS_PORT is the *host* publish port for the
# agent command WebSocket; the container always listens on 8003. docker-compose.yml sets
# backend AGENT_WS_URL to ws://agent:8003 (Docker network), independent of this value.
FEATURE_SERVER_PORT=8002
AGENT_WS_PORT=8003
# Docker Compose: optional override for in-container model bundle path (see docker-compose agent MODEL_DIR).
# Default in compose: /app/agent/model_storage/JackSparrow_IC_BTCUSD (rule-based IC).
# AGENT_MODEL_DIR=/app/agent/model_storage/JackSparrow_IC_BTCUSD

# -------------------------------------------------------------------
# Delta Exchange Credentials (required)
# -------------------------------------------------------------------
DELTA_EXCHANGE_API_KEY=your-delta-api-key
DELTA_EXCHANGE_API_SECRET=your-delta-api-secret
# Delta India testnet (required — runtime rejects production URLs)
DELTA_EXCHANGE_BASE_URL=https://cdn-ind.testnet.deltaex.org
# WSS uses the socket host (not cdn-ind). Client sends key-auth after connect: signature GET{unix_seconds}/live
WEBSOCKET_URL=wss://socket-ind.testnet.deltaex.org
# AI signals need working REST candles + tickers. If you see repeated 502/circuit-breaker in agent logs,
# check Delta status, host clock sync, and API key scope; change region only if your account supports it
# and set REST + WEBSOCKET_URL to the same cluster (see Delta API docs).
# Seconds without a good v2/ticker tick before polling REST GET /v2/tickers/{symbol}
MARKET_DATA_STALE_REST_POLL_SECONDS=30
# Minutes without candle closes before market data stream restart attempt
AGENT_NO_CANDLE_RESTART_MINUTES=2

# Delta market WebSocket client (agent). WEBSOCKET_URL above must match REST cluster (India vs testnet).
WEBSOCKET_ENABLED=true
WEBSOCKET_RECONNECT_ATTEMPTS=5
WEBSOCKET_RECONNECT_DELAY=5.0
WEBSOCKET_HEARTBEAT_INTERVAL=30.0
WEBSOCKET_FALLBACK_POLL_INTERVAL=60.0

DELTA_API_KEY=your-delta-api-key
DELTA_API_SECRET=your-delta-api-secret
DELTA_API_URL=https://cdn-ind.testnet.deltaex.org
# Sync order leverage on testnet before entry orders (RiskManager dynamic leverage; fail closed on API error)
SYNC_EXCHANGE_ORDER_LEVERAGE=true

# -------------------------------------------------------------------
# Backend Security & API Settings
# -------------------------------------------------------------------
# Rotate these in gitignored .env if they were ever committed or logged in reports.
JWT_SECRET_KEY=use-a-long-random-secret-min-32-chars
API_KEY=use-a-long-random-api-key-min-32-chars
# Legacy REST trading endpoints (disabled by default; use WebSocket commands instead)
ENABLE_DEPRECATED_REST_TRADING=false
# Browser-visible origins only (no Docker-internal hosts here)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000
# Optional: merged in backend for Docker/internal (default in compose: http://frontend:3000)
CORS_INTERNAL_ORIGINS=http://frontend:3000
# ENVIRONMENT=production with real secrets, or leave development and set STRICT_SECRETS=true to reject placeholders
# ENVIRONMENT=development
# STRICT_SECRETS=false
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
REDIS_MAX_CONNECTIONS=12
# Backend status command timeout (seconds) for get_status.
# Increase in CPU-heavy environments to reduce false websocket timeouts.
# AGENT_STATUS_COMMAND_TIMEOUT_SECONDS=15
# Backend status UX smoothing for transient agent command timeouts.
# During this grace window, backend reuses last-known-good agent status.
# AGENT_STATUS_TIMEOUT_GRACE_SECONDS=30

# Logging
LOG_LEVEL=INFO
BACKEND_LOG_LEVEL=INFO
AGENT_LOG_LEVEL=INFO
LOG_FORWARDING_ENABLED=false
LOG_FORWARDING_ENDPOINT=
LOG_INCLUDE_STACKTRACE=false
# Paper/signal audit timestamps use IST (Asia/Kolkata) as the primary clock; Docker Compose sets TZ on the agent container.
# TZ=Asia/Kolkata
# Realtime markdown audit under LOGS_ROOT (default logs/signal_audit/live_audit.md)
# SIGNAL_AUDIT_MD_ENABLED=true
# SIGNAL_AUDIT_MD_SUBPATH=signal_audit/live_audit.md

# -------------------------------------------------------------------
# Agent Configuration
# -------------------------------------------------------------------
AGENT_START_MODE=MONITORING
# Delta contract symbol for REST/WS (no ".P" suffix — TradingView-style BTCUSD.P is normalized in the agent)
AGENT_SYMBOL=BTCUSD
AGENT_INTERVAL=15m
FEATURE_SERVER_HOST=0.0.0.0
# Trading runtime: Delta testnet only (real orders; local paper simulation removed)
TRADING_MODE=testnet
DELTA_ENVIRONMENT=testnet
EXCHANGE_BACKEND=delta_live
DELTA_ENV=india_testnet
# Agent-only Delta order authority (default: only RiskApproved → execution may place orders)
AGENT_ONLY_DELTA_ORDERS=true
BLOCK_MANUAL_EXECUTE_TRADE=true
# NO-ML: rule-based Intelligence Component (no XGBoost artifacts)
IC_MODE=true
MODEL_DIR=./agent/model_storage/JackSparrow_IC_BTCUSD
REQUIRE_ML_SIGNAL_FOR_ORDERS=false
REQUIRE_ML_CONSENSUS_ALIGNMENT=false
REQUIRE_V43_GATES_FOR_ENTRY=false
AGENT_ORDER_ATTRIBUTION_WINDOW_SECONDS=3600
EXCHANGE_POSITION_RECONCILE_ENABLED=true
EXCHANGE_POSITION_RECONCILE_ORPHAN_MODE=close_orphan
EXCHANGE_POSITION_RECONCILE_INTERVAL_SECONDS=30
BLOCK_ENTRIES_ON_RECONCILE_DIVERGENCE=true
TRADING_KILL_SWITCH=false
HALT_TRADING_ON_CIRCUIT_BREAKER=true
ORDER_PERSISTENCE_ENABLED=true
ENFORCE_EXECUTION_SLIPPAGE_BPS=true
# Conservative production profile: see .env.production.example and reference/trading-persistence-model.md
# Removed (do not set): PAPER_TRADING_MODE, EXCHANGE_BACKEND=delta_paper_sim, RESET_PAPER_STATE_ON_STARTUP

# Risk Management
MAX_POSITION_SIZE=0.10
MAX_PORTFOLIO_HEAT=0.30
# Scalping defaults (0.25% / 0.3%); match Colab TP_PCT/SL_PCT after retrain.
STOP_LOSS_PERCENTAGE=0.008
TAKE_PROFIT_PERCENTAGE=0.016
MAX_DAILY_LOSS=0.05
MAX_DRAWDOWN=0.15
MAX_CONSECUTIVE_LOSSES=5
MIN_TIME_BETWEEN_TRADES=300

# Perpetual Futures Contract (Delta BTCUSD Perpetual)
CONTRACT_TYPE=perpetual_futures
PRODUCT_ID=84
SYMBOL=BTCUSD
CONTRACT_VALUE_BTC=0.001
TICK_SIZE=0.50
TAKER_FEE_RATE=0.0005
MAKER_FEE_RATE=0.0002
FUNDING_INTERVAL_HOURS=8
FUNDING_INTEREST_RATE=0.0001
DEFAULT_LEVERAGE=5
MAX_LEVERAGE=20
MIN_LEVERAGE=1
ISOLATED_MARGIN=true
FUNDING_STOP_ENABLED=true
FUNDING_STOP_THRESHOLD=0.0005
ORDER_TYPE=market
SLIPPAGE_BPS=5
MIN_LOT_SIZE=1
MAX_LOTS_PER_ORDER=100
ENABLE_FUNDING_FEATURES=true
ENABLE_OI_FEATURES=true
ENABLE_MARK_PRICE_FEATURES=true
ENABLE_ORDERBOOK_FEATURES=true
# First timeframe = primary candle close interval for the ML pipeline (~60 runs/hour at 1m).
ACTIVE_TIMEFRAMES=1m,5m,15m,30m,1h,2h

# Trading Session Defaults
INITIAL_BALANCE=20000.0
TRADING_MODE=testnet
TRADING_SYMBOL=BTCUSD
# Entry gate: trades are allowed only when confidence is >= 55%.
MIN_CONFIDENCE_THRESHOLD=0.55
# Optional: bypass v15/feature/MTF/SR/stale/debounce — only payload AI
# confidence >= AI_SIGNAL_MIN_ENTRY_CONFIDENCE plus price, margin, min lots, open-position rules.
# RiskManager.validate_trade still runs for every entry.
# AI_SIGNAL_MINIMAL_ENTRY_GATES=false
# AI_SIGNAL_MIN_ENTRY_CONFIDENCE=0.70
# Agent-first policy: force autonomous HOLD (still emits ML evidence for audit).
# AGENT_POLICY_FORCE_HOLD=false
# Strategy-first fusion: thesis and ML must agree (production after recovery validation).
# Recovery P0: ml_only unlocks gated ML flow while validating gate throughput.
AGENT_POLICY_MODE=ml_or_thesis
# Minimum confluence score 0-100 before entry (strategy-first pipeline).
# AGENT_TRADE_SCORE_MIN=70
# Require thesis+ML agreement for execution when mode is ml_and_thesis.
# REQUIRE_STRATEGY_ML_AGREEMENT=true
# When thesis is HOLD, adopt v43 gated ML (final_long/final_short) for perp long/short symmetry.
# AGENT_POLICY_ADOPT_GATED_ML_WHEN_THESIS_NEUTRAL=true
# Halt new entries when portfolio drawdown exceeds this percent.
# AGENT_DAILY_DRAWDOWN_HALT_PCT=4.0
# Live manual execute_trade: require non-empty manual_trade_audit_reason in WebSocket parameters.
# MANUAL_EXECUTE_REQUIRES_AUDIT_REASON_LIVE=true
# Optional: neutral midpoint used by binary xgboost_node probability-to-signal mapping.
# XGB_BINARY_DECISION_MIDPOINT=0.5
# Optional: threshold for "strong consensus" labeling in reasoning diagnostics.
# REASONING_CONSENSUS_LABEL_THRESHOLD=0.5
UPDATE_INTERVAL=900
TIMEFRAMES=3m,5m,15m

# Model Configuration — rule-based IC (metadata_ic.json only; no .pkl artifacts).
# Docker: compose sets MODEL_DIR from AGENT_MODEL_DIR; see IC_MODE block above.
# Canonical bundle: agent/model_storage/JackSparrow_IC_BTCUSD/metadata_ic.json
# JACKSPARROW_V43_ARTIFACT_BASENAME=model_artifact_v43_patched.pkl
MODEL_DISCOVERY_ENABLED=true
MODEL_AUTO_REGISTER=true

# MODEL_DISCOVERY_RECURSIVE=false

# --- JackSparrow v43 multi-head trade execution (see docs/v43_trade_execution_runbook.md) ---
# Bundle must export horizons{} (2/6/12/24 bars). Primary gate head defaults to 2 bars (scalp 10m).
JACKSPARROW_V43_FORWARD_TARGET_BARS=2
# Align debounce / max-hold / TP hints to thesis execution horizon when set (recommended true).
# JACKSPARROW_V43_ALIGN_EXECUTION_TO_HORIZON=true
# ml_and_thesis: validate thesis vs multi-head evidence (target + confirm heads, opposition veto).
# JACKSPARROW_V43_REQUIRE_HORIZON_FUSION_MATCH=true
# Gate 5: expected-return edge vs round-trip cost multiple (0.2 default for v43 regressor scale).
JACKSPARROW_V43_MIN_EDGE_COST_RATIO=0.2
# Training validation thresholds (percentiles on val preds; default 90/10 ≈ 10–15% coverage).
# V43_THRESHOLD_PERCENTILE_LONG=90
# V43_THRESHOLD_PERCENTILE_SHORT=10
# Optional meta-classifier stack on next Colab retrain (trade-quality gate; slower export).
# V43_USE_META_STACK=false
# Minimum 5m bars between entries when horizon alignment is off (default 1 ≈ 5 min).
JACKSPARROW_V43_TRADE_DEBOUNCE_BARS=1
# Gate 3: max entries per rolling hour / UTC day (scalping defaults).
JACKSPARROW_V43_MAX_TRADES_PER_HOUR=6
JACKSPARROW_V43_MAX_TRADES_PER_DAY=20
# Near-threshold band: treat expected_return within (threshold - epsilon) as a raw candidate.
JACKSPARROW_V43_NEAR_THRESHOLD_EPSILON=0.0002
# Soft floor for threshold resolution; keep below OOF P75 (~0.0005) so calibrated dt applies.
# JACKSPARROW_V43_SIGNAL_THRESHOLD_FLOOR=0.0005
# Symmetric shorts when expected_return < -short_threshold (perpetual futures; same v43 gates as long).
JACKSPARROW_V43_SHORT_EXECUTION_ENABLED=true
# Inference stack: meta_calibrator maps ensemble outputs to signed returns (recommended for live + scenario tests).
# regressor_mean can clip classifier probabilities to 0.1 ceiling — use only for recovery experiments.
JACKSPARROW_V43_INFERENCE_STACK=meta_calibrator
# Scenario harness / pre-deploy: python run_scenario_tests.py --save (see agent/testing/)
# Fail bundle load when metadata promotion audit finds meta_calibrator issues (zero shorts, low meta_auc).
# JACKSPARROW_V43_METADATA_PROMOTION_STRICT=false

# OI features (public ticker read-only; separate from testnet trading REST)
# JACKSPARROW_V43_OI_ENABLED=true
# JACKSPARROW_V43_OI_PUBLIC_BASE_URL=https://api.india.delta.exchange
# JACKSPARROW_V43_CANDLES_OI=300
# JACKSPARROW_V43_OI_FETCH_TIMEOUT_S=4.0
# Derivatives-state v3 (basis + microstructure + contract health)
# JACKSPARROW_V43_BASIS_ZSCORE_WINDOW=48
# JACKSPARROW_V43_CROWDING_BASIS_THRESHOLD=2.0
# JACKSPARROW_V43_CROWDING_OI_THRESHOLD=1.0
# JACKSPARROW_V43_CROWDING_FUNDING_X_OI_THRESHOLD=1.5
# JACKSPARROW_V43_PRICE_BAND_VETO_PCT=0.5
# JACKSPARROW_V43_CONTRACT_STATE_TTL_S=60

# Portfolio intelligence (staged rollout: shadow -> reduce -> block)
# Deterministic self-awareness (read-only introspection + memory outcome + advisory reflection)
# AGENT_INTROSPECTION_ENABLED=true
# AGENT_MEMORY_OUTCOME_BACKFILL_ENABLED=true
# AGENT_REFLECTION_ADVISORY_ENABLED=true
# AGENT_REFLECTION_POLICY_FEEDBACK_ENABLED=false
# REFLECTION_CALIBRATION_STEP_SIZE=0.02
# REFLECTION_CALIBRATION_MIN_SAMPLES=5
# AGENT_VECTOR_STORE_BACKEND=memory
# AGENT_VECTOR_STORE_QDRANT_COLLECTION=decision_contexts

# Enable for scenario tests (high_drawdown, high_confidence_bad_portfolio) and live enforcement after shadow validation.
# PORTFOLIO_INTELLIGENCE_ENABLED=true
# PORTFOLIO_INTELLIGENCE_SHADOW_MODE=false
# PORTFOLIO_INTELLIGENCE_REDUCE_ENABLED=true
# PORTFOLIO_INTELLIGENCE_BLOCK_ENABLED=true
# PORTFOLIO_MAX_HEAT_RATIO=0.85
# PORTFOLIO_MAX_SAME_SIDE_CONCENTRATION=0.70
# PORTFOLIO_MAX_CORRELATION_GROUP_FRACTION=0.55
# PORTFOLIO_CORRELATION_GROUPS_JSON={"crypto_major":["BTCUSD","ETHUSD","BTCUSDT","ETHUSDT"]}
# Recovery P0: allow entries in model "trending" regime (re-tighten after throughput validated).
JACKSPARROW_V43_BLOCK_TRENDING_ENTRIES=false
# P3: after stable flow (≥5 trades/day in ml_only), re-enable thesis fusion:
# AGENT_POLICY_MODE=ml_and_thesis
# AGENT_POLICY_ADOPT_GATED_ML_WHEN_THESIS_NEUTRAL=true
# Prefer tuning gates before lowering confidence.
# AI_SIGNAL_MIN_ENTRY_CONFIDENCE=0.70
# PAPER ONLY: bypass most legacy handler filters — not a live posture without review.
# RiskManager.validate_trade still runs on every entry.
# AI_SIGNAL_MINIMAL_ENTRY_GATES=false
# Optional paper validation floor (see config.py PAPER_TRADE_VALIDATION_*).
# PAPER_TRADE_VALIDATION_MODE=false

# --- JackSparrow v15 (removed from agent; do not enable) ---
# V15_SIGNAL_LOGIC_ENABLED=false
# V15_DISABLE_MTF_SYNTHESIS=true
# V15_FILTER_FEATURE_SOURCE_TF=5m
# Code defaults (sequential / capital-first): CONFIDENCE_PERCENTILE=70, EDGE_FLOOR=0.11, V15_MIN_EDGE_COST_RATIO=1.2.
# Uncomment to tighten v15 entry gate after retrain validation:
# CONFIDENCE_PERCENTILE=90
# EDGE_FLOOR=0.15
# V15_MIN_EDGE_COST_RATIO=2.0
# ATR_TRAILING_MULT=2.0
# MIN_HOLD_BARS=3
# EDGE_DECAY_THRESHOLD=0.05
# VOLATILITY_FILTER_ENABLED=true
# V15_ATR_PCT_FLOOR=0.0005
# V15_ADX_RANGING_MAX=25
# When true (default), v15 entry gate skips entries when ADX exceeds V15_ADX_RANGING_MAX (ranging regime).
# Set false to allow entries in stronger trends (strategy change — use with care).
# V15_ADX_REGIME_FILTER_ENABLED=true
# HTF_CACHE_TTL_SECONDS=840

# --- Trade caps (defaults in config.py: daily cap off, min gap off, MAX_TRADES_PER_HOUR=0 unlimited) ---
# Single open position per symbol is enforced in execution; margin checks stay on.
# Conservative rollback (re-enable artificial caps):
# V15_DAILY_TRADE_CAP_ENABLED=true
# V15_MIN_TRADE_GAP_ENABLED=true
# MAX_TRADES_PER_HOUR=3
# Optional: allow trending v15 entries (disable ADX ranging gate):
# V15_ADX_REGIME_FILTER_ENABLED=false
# Docker Compose sets REQUIRE_MODELS_ON_STARTUP=true by default; use false locally if you have no model artefacts.
# REQUIRE_MODELS_ON_STARTUP=false
# Persist decisions / closes to Postgres (requires DATABASE_URL + migrate_model_governance.py).
# PREDICTION_AUDIT_WRITES_ENABLED=true
# TRADE_OUTCOMES_WRITES_ENABLED=true
# Bounded Redis threshold learning (reads trade_outcomes).
# THRESHOLD_ADAPTER_ENABLED=true
# THRESHOLD_ADAPTER_INTERVAL_SECONDS=3600

# --- Adaptive drift + warm-start retrain (agent/learning/adaptive/) ---
# Off by default. When enabled, agent runs KS drift + optional warm-start XGBoost retrain
# with F1 gate; accepted models are saved as pipeline_{tf}_v_auto_<ts>.pkl and
# pipeline_{tf}_latest.pkl beside metadata (see docs/03-ml-models.md).
# ADAPTIVE_RETRAIN_ENABLED=false
# ADAPTIVE_RETRAIN_CHECK_INTERVAL_SECONDS=3600
# ADAPTIVE_RETRAIN_COOLDOWN_HOURS=12
# ADAPTIVE_DRIFT_ALPHA=0.01
# ADAPTIVE_DRIFT_STAT_THRESHOLD=0.10
# ADAPTIVE_DRIFT_FEATURE_LIMIT=5
# ADAPTIVE_RETRAIN_TIMEFRAMES=5m,15m
# ADAPTIVE_LABELED_DATA_SOURCE=none
# ADAPTIVE_LABELED_DATA_SOURCE=parquet
# ADAPTIVE_RETRAIN_PARQUET_DIR=./agent/model_storage/JackSparrow_v43_models_BTCUSD/adaptive_data
# (Place labeled_5m.parquet / labeled_15m.parquet with feature columns + int label 0/1/2.)
# ADAPTIVE_RETRAIN_STATE_PATH=adaptive_retrain_state.json
# Class weights (match notebook Cell 5): ADAPTIVE_CLASS_WEIGHT_SELL=1.3 ADAPTIVE_CLASS_WEIGHT_HOLD=0.5 ADAPTIVE_CLASS_WEIGHT_BUY=1.3
# ADAPTIVE_DRIFT_METRIC=ks
# ADAPTIVE_DRIFT_METRIC=psi
# ADAPTIVE_DRIFT_METRIC=either
# ADAPTIVE_DRIFT_PSI_THRESHOLD=0.25
# ADAPTIVE_DRIFT_PSI_BINS=10
# ADAPTIVE_PERFORMANCE_RETRAIN_ENABLED=false
# ADAPTIVE_PERFORMANCE_ROLLING_TRADES=50
# ADAPTIVE_PERFORMANCE_MIN_TRADES=30
# ADAPTIVE_PERFORMANCE_WIN_RATE_FLOOR=0.40
# ADAPTIVE_PERFORMANCE_PROFIT_FACTOR_FLOOR=0.85
# ADAPTIVE_PERFORMANCE_MAX_DD_CEILING=0.35
# ADAPTIVE_VALIDATION_SCORECARD_ENABLED=false
# FEATURE_SERVER_FAIL_CLOSED_NO_CANDLES=true
# STRICT_CANDLE_VALIDATION_ENABLED=true
# STRICT_CANDLE_VALIDATION_MIN_ROWS=50

# --- Multi-timeframe (MTF) gates (see agent/core/mtf_decision_engine.py) ---
# Defaults in config.py match raw XGB probabilities; tune using validation percentiles in
# notebooks/JackSparrow_Trading_Colab_v5.ipynb (section 5.2b) after each retrain.
# MTF_DECISION_ENGINE_ENABLED=true
# 5m-primary scalping: primary TF drives BUY/SELL; 15m only adjusts position size (never blocks).
# MTF_SIGNAL_ARCHITECTURE=short_tf_primary
# MTF_PRIMARY_SIGNAL_TIMEFRAME=5m
# MTF_CONTEXT_TIMEFRAME=15m
# MTF_PRIMARY_DEAD_ZONE=0.05
# MTF_PRIMARY_EDGE_LONG=0.08
# MTF_PRIMARY_EDGE_SHORT=0.08
# MTF_PRIMARY_STRONG_LONG_MIN_PROB=0.55
# MTF_PRIMARY_STRONG_SHORT_MIN_PROB=0.58
# MTF_CONTEXT_AGREE_EDGE=0.02
# MTF_CONTEXT_ALIGNED_SIZE_MULTIPLIER=1.15
# MTF_CONTEXT_MISALIGNED_SIZE_MULTIPLIER=0.75
# Default stack: 15m trend + 5m entry (matches notebook intro). For higher-TF trend + 15m entry
# (e.g. 1h trend confirms 15m entry), set:
#   MTF_TREND_TIMEFRAME=1h
#   MTF_ENTRY_TIMEFRAME=15m
# (Requires exported models for those timeframes under MODEL_DIR.)
# MTF_TREND_FALLBACK_TIMEFRAMES=30m,1h,2h,4h
# MTF_ENTRY_FALLBACK_TIMEFRAMES=15m,30m,1h
# MTF_ENTRY_MIN_CONFIDENCE=0.52
# MTF_TREND_MIN_BUY_PROB=0.50
# MTF_TREND_MIN_SELL_PROB=0.50
# MTF_ENTRY_MIN_BUY_PROB=0.50
# MTF_ENTRY_MIN_SELL_PROB=0.50
# MTF_STRONG_MIN_BUY_PROB=0.60
# MTF_STRONG_MIN_SELL_PROB=0.60
# MTF_MIN_CONFIDENCE_GAP=0.05
# MTF_TREND_SIGNAL_THRESHOLD=0.1
# MTF_ENTRY_SIGNAL_THRESHOLD=0.15
# Optional: v4 binary long/short only — force neutral when |buy_prob-sell_prob| is tiny (0 = off).
# ENTRY_LONG_SHORT_MIN_GAP=0.05
# Prob-diff MTF (defaults on in config): trend/entry use signed (buy-sell) edges vs absolute floors.
# MTF_TREND_USE_PROB_DIFF=true
# MTF_TREND_PROB_DIFF_EDGE=0.05
# MTF_ENTRY_USE_PROB_DIFF=true
# MTF_ENTRY_PROB_DIFF_EDGE=0.08
# MTF_STRONG_ENTRY_PROB_DIFF=0.15
# MTF_ENTRY_MIN_MAX_PROB_FLOOR=0.0
# Selective scalping: require |buy-sell| in top (100-P)% of recent bars (needs symbol in reasoning).
# MTF_ENTRY_STRENGTH_PERCENTILE_ENABLED=false
# MTF_ENTRY_STRENGTH_PERCENTILE=80
# MTF_ENTRY_STRENGTH_PERCENTILE_MIN_SAMPLES=30
# ENTRY_MIN_VOLATILITY_FOR_TRADE=0.0
# ENTRY_MIN_ATR_PCT_OF_PRICE=0.0

# Agent Communication
AGENT_COMMAND_QUEUE=agent_commands
AGENT_RESPONSE_QUEUE=agent_responses
# Local backend: agent WS on localhost. Full Docker stack: compose overrides to ws://agent:8003.
AGENT_WS_URL=ws://localhost:8003
USE_AGENT_WEBSOCKET=true
# Local agent → backend events WebSocket. Docker Compose sets ws://backend:8000/ws/agent on the agent service.
BACKEND_WS_URL=ws://localhost:8000/ws/agent

# -------------------------------------------------------------------
# Frontend (public URLs; API key is server-only via Next.js /api/backend proxy)
# -------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_BACKEND_PROXY_BASE=/api/backend

# -------------------------------------------------------------------
# Optional: GHCR image names for production deploy (docker compose pull + up --no-build)
# -------------------------------------------------------------------
# BACKEND_IMAGE=ghcr.io/<org>/jacksparrow-backend:latest
# AGENT_IMAGE=ghcr.io/<org>/jacksparrow-agent:latest
# FRONTEND_IMAGE=ghcr.io/<org>/jacksparrow-frontend:latest

# -------------------------------------------------------------------
# Optional Services
# -------------------------------------------------------------------
# Local default (non-Docker). Docker Compose overrides to http://qdrant:6333.
QDRANT_URL=http://localhost:6333
# Required for docker compose (qdrant service auth). Use any non-empty secret locally.
QDRANT_API_KEY=changeme
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
